# ─────────────────────────────────────────────────────────────────────────────
# Database (MongoDB)
# ─────────────────────────────────────────────────────────────────────────────
# Local MongoDB example:
DATABASE_URL="mongodb://127.0.0.1:27017/libplay"
# MongoDB Atlas example (replace <db_password> with your password OR set DATABASE_PASSWORD separately):
# DATABASE_URL="mongodb+srv://<username>:<db_password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
# DATABASE_PASSWORD="your-atlas-password"
DATABASE_NAME="libplay"

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────
# JWT Secret — change this to a long random string in production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─────────────────────────────────────────────────────────────────────────────
# Storage Server (College / Self-Hosted Machine)
# ─────────────────────────────────────────────────────────────────────────────
# Full base URL of the college storage server (e.g. ngrok tunnel or LAN IP).
# Leave unset when running the app directly on the college server.
# STORAGE_SERVER_URL="https://xxxx.ngrok-free.app"

# Shared secret used by the Vercel backend to authenticate with the storage server.
# Must match the value set on the college server.
# STORAGE_SECRET="change-this-to-a-strong-random-secret"

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Browser) — public env vars (prefixed with NEXT_PUBLIC_)
# ─────────────────────────────────────────────────────────────────────────────
# Same base URL as STORAGE_SERVER_URL — exposed to the browser so the frontend
# can upload large files (>4.5 MB) directly to the college server, bypassing
# Vercel's request-size limit.
# NEXT_PUBLIC_STORAGE_SERVER_URL="https://xxxx.ngrok-free.app"
